{
  "name": "dumbridge-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --cache-dir=.turbo/cache",
    "changeset:status": "bun scripts/changeset-status.ts",
    "check": "turbo run check --cache-dir=.turbo/cache && ultracite check .",
    "ci:publish": "changeset publish",
    "ci:version": "changeset version && bun install",
    "fix": "turbo run fix --cache-dir=.turbo/cache && ultracite fix .",
    "test": "turbo run test --cache-dir=.turbo/cache",
    "typecheck": "turbo run typecheck --cache-dir=.turbo/cache",
    "verify": "bun run changeset:status && bun run check && bun run typecheck && bun run test && bun run build && bun run verify:tarball",
    "verify:tarball": "turbo run verify:tarball --cache-dir=.turbo/cache"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "2.31.0",
    "@effect/language-service": "0.87.0",
    "turbo": "2.10.5",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  }
}
