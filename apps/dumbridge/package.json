{
  "name": "dumbridge",
  "version": "1.0.1",
  "description": "A short-lived, read-only bridge from one local directory to a cloud coding agent",
  "keywords": [
    "agent",
    "bridge",
    "bun",
    "cli",
    "cloud-agent",
    "coding-agent",
    "iroh",
    "quic",
    "read-only",
    "remote-access"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faw01/dumbridge.git",
    "directory": "apps/dumbridge"
  },
  "bugs": {
    "url": "https://github.com/faw01/dumbridge/issues"
  },
  "homepage": "https://github.com/faw01/dumbridge#readme",
  "bin": {
    "dumbridge": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --outfile=dist/cli.js --external 'effect' --external 'effect/*' --external '@effect/platform-bun' --external '@effect/platform-bun/*' --external '@number0/iroh' --external 'just-bash'",
    "check": "ultracite check src test scripts package.json tsconfig.json",
    "fix": "ultracite fix src test scripts package.json tsconfig.json",
    "prepack": "bun run build && bun run verify:tarball",
    "test": "bun --bun vitest run && bun test cli.test.ts cli-bridge.test.ts cli-detach.test.ts verify-npm-tarball.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:tarball": "bun scripts/verify-npm-tarball.ts"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.98",
    "@effect/platform-node-shared": "4.0.0-beta.98",
    "@number0/iroh": "npm:dumbridge-iroh@1.0.0",
    "effect": "4.0.0-beta.98",
    "just-bash": "3.1.0"
  },
  "devDependencies": {
    "@dumbridge/bridge-key": "workspace:*",
    "@dumbridge/bridge-transport": "workspace:*",
    "@dumbridge/pull-transfer": "workspace:*",
    "@dumbridge/safe-shell": "workspace:*",
    "@dumbridge/served-root": "workspace:*",
    "@dumbridge/typescript-config": "workspace:*",
    "@dumbridge/wire": "workspace:*",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/bun": "1.3.14",
    "vitest": "4.1.10"
  }
}
