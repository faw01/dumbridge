{
  "name": "dumbridge",
  "version": "0.1.0",
  "description": "A short-lived, read-only bridge from one local directory to a cloud coding agent",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faw01/dumbridge.git",
    "directory": "apps/dumbridge"
  },
  "bugs": {
    "url": "https://github.com/faw01/dumbridge/issues"
  },
  "homepage": "https://github.com/faw01/dumbridge#readme",
  "bin": {
    "dumbridge": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --packages=external --outfile=dist/cli.js",
    "check": "ultracite check src test scripts package.json tsconfig.json",
    "fix": "ultracite fix src test scripts package.json tsconfig.json",
    "pack:check": "bun scripts/verify-pack.ts",
    "prepack": "bun run build && bun run pack:check",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.98",
    "@number0/iroh": "1.0.0",
    "effect": "4.0.0-beta.98",
    "just-bash": "3.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14"
  }
}
