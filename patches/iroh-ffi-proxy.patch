+
+    #[napi]
+    pub fn ca_extra_roots_pem(&self, pem: String) -> Result<()> {
+        use rustls_pki_types::{CertificateDer, pem::PemObject};
+
+        let certs = CertificateDer::pem_slice_iter(pem.as_bytes())
+            .collect::<std::result::Result<Vec<_>, _>>()
+            .map_err(|e| anyhow::anyhow!("failed to parse CA PEM: {e}"))?;
+        if certs.is_empty() {
+            return Err(anyhow::anyhow!("no certificates found in CA PEM").into());
+        }
+        let ca = iroh::tls::CaTlsConfig::default().with_extra_roots(certs);
+        self.map(|b| b.ca_tls_config(ca));
+        Ok(())
+    }
